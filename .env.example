DATABASE_URL=sqlite:///./actioninbox.db
# MySQL example (replace placeholders; do not commit credentials):
# DATABASE_URL=mysql+pymysql://actioninbox:change-me@mysql:3306/actioninbox?charset=utf8mb4
LOCAL_DEMO_AUTH_ENABLED=true
OPENAI_API_KEY=
# Optional path inside the server/container to an additional trusted CA bundle.
OPENAI_CA_BUNDLE=
# Server-side Gmail OAuth values. Never commit real values or the downloaded JSON.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://actioninbox.16-192-83-71.nip.io/auth/google/callback
# Generate separately for each environment with Fernet.generate_key().
TOKEN_ENCRYPTION_KEY=
# Strong random bearer token for the authenticated read-only MCP endpoint.
MCP_ACCESS_TOKEN=
MCP_USER_ID=00000000-0000-0000-0000-000000000001
REPOSITORY_ORIGIN=https://github.com/a0527645787-oss/action-inbox-build-week.git
